rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Shape guards for public ticket submissions.
    function isShortString(v) {
      return v is string && v.size() > 0 && v.size() <= 500;
    }
    function isLongString(v) {
      return v is string && v.size() <= 10000;
    }
    function isEmail(v) {
      return v is string && v.size() <= 320 && v.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }
    function isReasonableTicket(d) {
      return d.keys().hasAll(['customer', 'email', 'issue']) &&
        isShortString(d.customer) &&
        isEmail(d.email) &&
        isLongString(d.issue) &&
        // total document size soft-cap: reject payloads over ~50KB worth of fields
        d.size() <= 40;
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isSelf(uid);
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isSelf(uid) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]))
      );
      allow delete: if isAdmin();
    }

    // ── Invites ───────────────────────────────────────────────────────────────

    match /invites/{inviteId} {
      allow read:   if isAdmin() ||
        (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow create: if isAdmin();
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.email == request.auth.token.email);
    }

    // ── Tickets ───────────────────────────────────────────────────────────────
    // Public can CREATE (customer-facing /submit form) — but the payload must
    // match a tight shape. All other operations require an authenticated agent.
    // Delete is admin-only so agents can't erase history.

    match /tickets/{ticketId} {
      allow create: if isReasonableTicket(request.resource.data);
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Customers ─────────────────────────────────────────────────────────────
    // Any agent can read (they need to see who they're replying to) and
    // create/update. Only admins can delete — PII deletion shouldn't be
    // a one-click action for every agent.

    match /customers/{customerId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // A notification doc should carry a `uid` field identifying its recipient.
    // Only that user (or an admin) can read/update/delete it.

    match /notifications/{notifId} {
      allow read, update, delete: if isAuthenticated() && (
        isAdmin() || resource.data.uid == request.auth.uid
      );
      // Creates are authenticated; the server-side flow writes these.
      allow create: if isAuthenticated();
    }

    // ── Canned Responses ──────────────────────────────────────────────────────

    match /cannedResponses/{crId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Settings ──────────────────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    // Only participants can read or write a conversation.
    // Messages: restricted to participants of the parent conversation.

    match /conversations/{convId} {
      allow read:   if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        // Messages are immutable once sent; no update/delete path.
      }

      match /typing/{uid} {
        allow read:          if isAuthenticated();
        allow write, delete: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // Default deny for any collection not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
